{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "./dist/server",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "declaration": false,
    "noEmit": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "src/server/**/*",
    "src/shared/**/*",
    "src/sync/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/components",
    "src/pages",
    "src/features",
    "src/sync/electron-integration.ts",
    "src/sync/production-sync-setup.ts",
    "src/sync/test/**/*",
    "src/server/**/__tests__/**/*",
    "src/server/**/*.test.ts",
    "src/server/saas/repositories/supabase/saas-supabase-extras.repository.ts",
    "src/lib/app-mode.ts",
    "src/lib/app-mode.server.ts"
  ]
}
