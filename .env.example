# ============================================
# GREAT OLIVE - Backend Environment
# ============================================

# === Environnement Général ===
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:5173

# ============================================
# BASE DE DONNÉES LOCALE (SQLite) - PRIORITAIRE
# ============================================
# L'application fonctionne exclusivement avec SQLite en local.
# Le chemin est géré automatiquement dans src/server/db/database.ts
# (data/database.db)

# ============================================
# SUPABASE - Synchronisation Périodique
# ============================================
# L'application reste sur SQLite comme source de vérité.
# Toutes les X minutes (si connecté à internet), elle pousse les données vers Supabase.

# URL de ton projet Supabase
SUPABASE_URL=https://ton-project-ref.supabase.co

# Clé Service Role (obligatoire côté backend - NE JAMAIS utiliser la anon key)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Chaîne de connexion Postgres directe (recommandée pour les requêtes batch)
# Va dans Supabase → Project Settings → Database → Connection string → Direct connection
DATABASE_URL=postgresql://postgres.ton-project-ref:TON_MOT_DE_PASSE@db.ton-project-ref.supabase.co:5432/postgres

# ============================================
# CONFIGURATION DE LA SYNCHRONISATION
# ============================================

# Active la synchronisation SQLite → Supabase
ENABLE_SUPABASE_SYNC=true

# Intervalle entre chaque synchronisation (en millisecondes)
# 60000 = 1 minute (valeur recommandée pour commencer)
SUPABASE_SYNC_INTERVAL_MS=60000

# Synchroniser automatiquement au démarrage du serveur ?
SUPABASE_SYNC_ON_STARTUP=true

# Nombre maximum de tentatives par enregistrement en cas d'échec
SUPABASE_SYNC_MAX_RETRIES=5

# Durée maximale d'une synchronisation (en ms) avant timeout
SUPABASE_SYNC_TIMEOUT_MS=120000

# ============================================
# LOGS & DEBUG
# ============================================

# Niveau de logs : debug | info | warn | error
LOG_LEVEL=info

# Active les logs détaillés de la synchronisation (très verbeux)
SYNC_DEBUG=false

# ============================================
# PULL SYNC: Supabase → SQLite (CRITICAL for QR orders)
# ============================================
# Active le pull léger pour synchroniser les commandes QR de Supabase vers SQLite
ENABLE_SUPABASE_PULL=true
SUPABASE_PULL_INTERVAL_MS=8000          # Intervalle entre chaque pull (ms)
SUPABASE_PULL_LOOKBACK_MIN=120          # Lookback en minutes pour le bootstrap

# ============================================
# OPTIONS FUTURES (laisser commenté pour l'instant)
# ============================================

# DB_TYPE=sqlite                 # Pour supporter plus tard SQLite + Postgres
# SYNC_DIRECTION=both            # sqlite-to-supabase | supabase-to-sqlite | both
# SYNC_CONFLICT_RESOLUTION=last_write_wins

# ============================================
# FRONTEND CONFIGURATION
# ============================================
# VITE_API_BASE_URL=https://ekala-api.onrender.com
VITE_PUBLIC_MENU_BASE_URL=https://ekala.vercel.app
CORS_ORIGINS=https://ekala.vercel.app

# Application Display Name (single source of truth)
VITE_APP_NAME="EKALA"
