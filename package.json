{
  "name": "ekala",
  "version": "1.0.0",
  "description": "",
  "main": "dist/main/main.js",
  "homepage": "./",
  "scripts": {
    "dev": "npm run build:main && concurrently \"npm run server:fast\" \"wait-on http://localhost:3001/health && vite\" \"wait-on http://localhost:5173 && electron .\"",
    "dev:web": "npm run build:main && concurrently \"npm run server:fast\" \"wait-on http://localhost:3001/health && vite --open\"",
    "build": "npm run build:main && npm run build:server && npm run build:renderer",
    "build:renderer": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:main": "mkdir -p dist/main && cp src/main/main.js dist/main/main.js && tsc --project tsconfig.electron.json --outDir dist/main/preload && test -f dist/main/main.js",
    "build:electron": "npm run build:main && npm run build:server && vite build --config vite.config.electron.ts",
    "dist": "npm run build:electron && electron-builder",
    "rebuild:sqlite": "npm rebuild better-sqlite3",
    "server": "npm run build:server && npm run rebuild:sqlite && node dist/server/server/server.js",
    "server:fast": "npm run build:server && node dist/server/server/server.js",
    "build:vercel": "npm run build:renderer",
    "build:render": "npm run build:server",
    "electron": "electron .",
    "test": "npx jest",
    "test:unit": "npx jest --testPathPatterns=unit",
    "test:integration": "npx jest --testPathPatterns=integration",
    "test:load": "npx jest --testPathPatterns=load",
    "test:e2e": "npx jest --testPathPatterns=e2e",
    "test:coverage": "npx jest --coverage",
    "test:watch": "npx jest --watch"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "com.ekala.pos",
    "productName": "EKALA",
    "asar": true,
    "npmRebuild": false,
    "files": [
      "dist/main/**/*",
      "dist/server/**/*",
      "dist/renderer/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build"
    },
    "extraResources": [
      {
        "from": "data",
        "to": "data"
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "afterPack": "./bin/electron-after-pack.js"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/electron": "^1.4.38",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.1",
    "jest": "^30.4.2",
    "tailwindcss": "^3.4.19",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "@fontsource/dm-sans": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@supabase/supabase-js": "^2.106.1",
    "@tanstack/react-query": "^5.100.10",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node-cron": "^3.0.11",
    "@types/node-fetch": "^2.6.13",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.14.0",
    "node-cron": "^4.5.0",
    "node-fetch": "^3.3.2",
    "nodemailer": "^8.0.7",
    "pdf-to-printer": "^5.8.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.0",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.15.0",
    "twilio": "^6.0.2",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  }
}
